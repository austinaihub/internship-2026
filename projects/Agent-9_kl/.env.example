# ==============================================================================
# Agent-9 Environment Variables
# Copy this file to .env and fill in your actual keys.
# Never commit the .env file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM — OpenAI (used by TrendAnalyzer, Writer, ImageGenerator, Publisher)
# Models in use: gpt-4o (planner/trend), gpt-4o-mini (writer/image prompt/publisher)
# ------------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------------------------------------------
# Image Generation — Google Gemini (used by ImageGeneratorAgent)
# Model in use: gemini-3.1-flash-image-preview
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# News Search — Exa.ai (used by ExaSearch tool)
# Required when EXA_ENABLED=True in config.py
# ------------------------------------------------------------------------------
EXA_API_KEY=your_exa_api_key_here

# ------------------------------------------------------------------------------
# Observability — LangSmith (used by @traceable decorators throughout)
# Set LANGCHAIN_TRACING_V2=true to enable tracing
# ------------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=Agent-9

# ------------------------------------------------------------------------------
# Output — Local file output directory
# Used by ImageGeneratorAgent and PublisherAgent to save images and HTML previews
# Defaults to "outputs" if not set
# ------------------------------------------------------------------------------
OUTPUT_DIR=outputs
