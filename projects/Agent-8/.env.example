# Copy this file to `.env` and fill in your keys:
#   cp .env.example .env
#
# Run apps from `projects/Agent-8` OR use the updated load_dotenv paths in main.py / app.py
# (they load `.env` next to those files).

# --- OpenAI (required) ---
# Used by ChatOpenAI in trend analyzer, planner, writer, publisher, and image prompt helper.
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Exa (required for news search; EXA_ENABLED is True in config.py) ---
EXA_API_KEY=

# --- Google Gemini (required for image generation) ---
GEMINI_API_KEY=

# --- LangSmith (optional; tracing + Streamlit “LangSmith Analytics” tab) ---
# If LANGCHAIN_TRACING_V2=true but LANGCHAIN_API_KEY is empty/wrong, runs still work but the
# console will spam LangSmith 401 errors. Use false until you add a valid key.
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=Agent-8

# --- Optional paths ---
# OUTPUT_DIR=outputs
